# OpenAI API key (required for LLM analysis of paper abstracts)
OPENAI_API_KEY=sk-your-key-here

# MongoDB connection string
MONGODB_URI=mongodb+srv://username:password@cluster.mongodb.net/?retryWrites=true&w=majority

# MongoDB database name (default: perp_autism_research)
MONGODB_DATABASE=perp_autism_research

# Email for PubMed API access (NCBI requires this)
PUBMED_EMAIL=your-email@example.com

# Optional: OpenAI model (default: gpt-4o-mini, use gpt-4o for higher quality)
# OPENAI_MODEL=gpt-4o-mini

# Optional: Max papers to fetch per PubMed query (default: 50)
# PUBMED_MAX_RESULTS=50

# Optional: Papers to process per pipeline run (default: 20)
# PIPELINE_BATCH_SIZE=20
